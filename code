#define EEG_PIN 34

#define IN1 25
#define IN2 26
#define IN3 27
#define IN4 14

#define FILTER_SIZE 10

int threshold = 2000;

int buffer[FILTER_SIZE];
int bufferIndex = 0;

void setup()
{
Serial.begin(115200);

pinMode(IN1,OUTPUT);
pinMode(IN2,OUTPUT);
pinMode(IN3,OUTPUT);
pinMode(IN4,OUTPUT);

pinMode(EEG_PIN,INPUT);
}

void forward()
{
digitalWrite(IN1,HIGH);
digitalWrite(IN2,LOW);

digitalWrite(IN3,HIGH);
digitalWrite(IN4,LOW);
}

void stopMotor()
{
digitalWrite(IN1,LOW);
digitalWrite(IN2,LOW);
digitalWrite(IN3,LOW);
digitalWrite(IN4,LOW);
}

void loop()
{

int rawEEG = analogRead(EEG_PIN);

buffer[bufferIndex] = rawEEG;
bufferIndex = (bufferIndex + 1) % FILTER_SIZE;

long sum = 0;

for(int i=0;i<FILTER_SIZE;i++)
{
sum += buffer[i];
}

int filteredEEG = sum / FILTER_SIZE;

Serial.print("Filtered: ");
Serial.println(filteredEEG);

if(filteredEEG > threshold)
{
forward();
Serial.println("Robot Moving Forward");
}
else
{
stopMotor();
Serial.println("Robot Stopped");
}

delay(50);

}